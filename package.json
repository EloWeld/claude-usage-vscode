{
  "name": "claude-usage-bars",
  "author": {
    "name": "Jonathan Mackay",
    "url": "https://github.com/jjsmackay"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EloWeld/claude-usage-vscode"
  },
  "homepage": "https://github.com/EloWeld/claude-usage-vscode#readme",
  "bugs": {
    "url": "https://github.com/EloWeld/claude-usage-vscode/issues"
  },
  "license": "MIT",
  "displayName": "Claude Usage Bars",
  "description": "Highly customizable Claude Code usage in your status bar — 13 styles, a live settings panel, burn-rate analytics, and separate session/weekly bars.",
  "version": "0.3.1",
  "publisher": "mtglitch",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "usage",
    "status bar",
    "rate limit",
    "token usage",
    "statusline",
    "anthropic",
    "monitor"
  ],
  "icon": "resources/claude-color.png",
  "galleryBanner": {
    "color": "#2b2118",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-usage.noop",
        "title": "Claude Usage: No-op"
      },
      {
        "command": "claude-usage.refresh",
        "title": "Refresh Claude Usage"
      },
      {
        "command": "claude-usage.login",
        "title": "Login to Claude Code"
      },
      {
        "command": "claude-usage.openSettings",
        "title": "Claude Usage: Open Appearance Settings"
      },
      {
        "command": "claude-usage.openUsage",
        "title": "Claude Usage: Open Usage Panel"
      },
      {
        "command": "claude-usage.openMenu",
        "title": "Claude Usage: Menu"
      }
    ],
    "configuration": {
      "title": "Claude Status Bar",
      "properties": {
        "claudeUsage.updateInterval": {
          "type": "number",
          "default": 300,
          "description": "Update interval in seconds (default: 300 = 5 minutes)"
        },
        "claudeUsage.showNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show notifications when usage is high"
        },
        "claudeUsage.statusBarDisplay": {
          "type": "string",
          "enum": [
            "both",
            "session",
            "weekly",
            "highest"
          ],
          "enumDescriptions": [
            "Show both session (5h) and weekly (7d): e.g. 45% · 23%",
            "Show session (5-hour window) only",
            "Show weekly (7-day window) only",
            "Show whichever is higher (original behavior)"
          ],
          "default": "both",
          "description": "Which usage window to display in the status bar"
        },
        "claudeUsage.statusBarStyle": {
          "type": "string",
          "enum": [
            "percent",
            "dual",
            "dots",
            "brackets",
            "minimal",
            "blocks",
            "braille",
            "gradient",
            "vmeter",
            "vtwin",
            "vgauge",
            "iconmeter",
            "iconsmall"
          ],
          "enumDescriptions": [
            "ASCII — percent, e.g. ✼ 45%",
            "ASCII — session · weekly, e.g. ✼ 45% · 23%",
            "ASCII — dot meter, e.g. ✼ ●●●●●○○○○○ 45%",
            "ASCII — bracket bar, e.g. ✼ [####······] 45%",
            "ASCII — minimal, e.g. 45%",
            "Graphic — block bar, e.g. ✼ ▰▰▰▰▱▱▱▱ 45%",
            "Graphic — braille meter, e.g. ✼ ⣿⣿⣦⣀ 45%",
            "Graphic — gradient bar, e.g. ✼ ▓▓▓▓░░░░ 45%",
            "Vertical — single meter, e.g. ✼ ▆ 45%",
            "Vertical — twin bars (session vs weekly), e.g. ✼ ▆▃ 45·23",
            "Vertical — smooth gauge, e.g. ✼ ███▄▁▁▁▁ 45%",
            "Icon — codicon circle meter (vector icons)",
            "Icon — codicon circle meter, smaller circles"
          ],
          "default": "vgauge",
          "description": "How the usage is rendered in the status bar. Use the Appearance Settings panel for a live preview."
        },
        "claudeUsage.statusBarStyleWeekly": {
          "type": "string",
          "enum": [
            "same",
            "percent",
            "dots",
            "brackets",
            "blocks",
            "braille",
            "gradient",
            "vmeter",
            "vgauge",
            "iconmeter",
            "iconsmall"
          ],
          "default": "vmeter",
          "description": "Style for the weekly bar when Window = Both. 'same' uses the main style. Applies to bar styles only."
        },
        "claudeUsage.statusBarIcon": {
          "type": "string",
          "default": "✼",
          "description": "Leading icon shown before the usage (leave empty to hide). Ignored by the 'minimal' style."
        },
        "claudeUsage.barLength": {
          "type": "number",
          "default": 8,
          "minimum": 4,
          "maximum": 40,
          "description": "Number of segments in bar-based styles (dots, brackets, blocks, braille, gradient, vertical gauge)"
        },
        "claudeUsage.colorEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Tint the status bar text yellow/red as usage crosses the warn/critical thresholds"
        },
        "claudeUsage.warnThreshold": {
          "type": "number",
          "default": 75,
          "minimum": 0,
          "maximum": 100,
          "description": "Usage percent at which the status bar turns yellow"
        },
        "claudeUsage.critThreshold": {
          "type": "number",
          "default": 90,
          "minimum": 0,
          "maximum": 100,
          "description": "Usage percent at which the status bar turns red"
        },
        "claudeUsage.normalColor": {
          "type": "string",
          "default": "",
          "description": "Custom hex color for normal usage (e.g. #cccccc). Empty = theme default."
        },
        "claudeUsage.warnColor": {
          "type": "string",
          "default": "",
          "description": "Custom hex color for the warn level (e.g. #e5c07b). Empty = theme warning color."
        },
        "claudeUsage.critColor": {
          "type": "string",
          "default": "",
          "description": "Custom hex color for the critical level (e.g. #e06c75). Empty = theme error color."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "vscode:publish": "vsce publish",
    "compile": "tsc -p ./",
    "vscode:package": "vsce package",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npm run compile && mocha out/test/suite/progress-bar.test.js out/test/suite/time-formatter.test.js --ui tdd --color"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.28.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^4.9.3",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.36",
    "axios": "^1.6.0"
  }
}
